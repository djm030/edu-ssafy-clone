# Copy this file to .env for local Docker Compose.
# Replace every change-me value before using a shared or production-like environment.
COMPOSE_PROJECT_NAME=ssafy-clone
TZ=Asia/Seoul
SPRING_PROFILES_ACTIVE=docker

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=ssafy_clone
MYSQL_PORT=3306
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=${MYSQL_ROOT_PASSWORD}

REDIS_PORT=6379

RABBITMQ_DEFAULT_USER=ssafy
RABBITMQ_DEFAULT_PASS=change-me-rabbit-password
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
SPRING_RABBITMQ_USERNAME=${RABBITMQ_DEFAULT_USER}
SPRING_RABBITMQ_PASSWORD=${RABBITMQ_DEFAULT_PASS}

BACKEND_IMAGE=ssafy-clone-backend:local
FRONTEND_IMAGE=ssafy-clone-frontend:local
BACKEND_PORT=8080
HTTP_PORT=80
EDUSSAFY_AUTH_ALLOW_NOOP_PASSWORDS=false
SERVER_SERVLET_SESSION_TIMEOUT=30m
SERVER_SERVLET_SESSION_COOKIE_SECURE=false
SERVER_SERVLET_SESSION_COOKIE_SAME_SITE=lax

# Production-like profile checklist:
# - Set SPRING_PROFILES_ACTIVE=prod.
# - Set SERVER_SERVLET_SESSION_COOKIE_SECURE=true behind HTTPS.
# - Set SERVER_SERVLET_SESSION_COOKIE_SAME_SITE=strict unless an external SSO/form flow requires lax.
# - Provide SPRING_DATASOURCE_URL, SPRING_DATASOURCE_USERNAME, SPRING_DATASOURCE_PASSWORD,
#   SPRING_RABBITMQ_USERNAME, and SPRING_RABBITMQ_PASSWORD from a secret store.
# SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/ssafy_clone?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=utf8

ELASTIC_VERSION=8.15.3
ELASTIC_PORT=9200
KIBANA_PORT=5601
LOGSTASH_BEATS_PORT=5044
LOGSTASH_TCP_PORT=5000
